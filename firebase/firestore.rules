rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasCurrentUserProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid));
    }

    function currentUserProfile() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid));
    }

    function canBrowseDiscover() {
      return hasCurrentUserProfile()
        && currentUserProfile().data.questionnaireCompleted == true
        && currentUserProfile().data.discoverVisible == true;
    }

    function numberInRange(value, minValue, maxValue) {
      return (
          value is int
          || value is float
        )
        && value >= minValue
        && value <= maxValue;
    }

    function validFactorScores(scores) {
      return scores is map
        && scores.keys().hasOnly([
          'neuroticism',
          'extraversion',
          'dominance',
          'ruleAdaptation',
          'empathy',
          'stressResponse',
          'feedbackNeed',
          'cooperation',
        ])
        && numberInRange(scores.neuroticism, 0, 10)
        && numberInRange(scores.extraversion, 0, 10)
        && numberInRange(scores.dominance, 0, 10)
        && numberInRange(scores.ruleAdaptation, 0, 10)
        && numberInRange(scores.empathy, 0, 10)
        && numberInRange(scores.stressResponse, 0, 10)
        && numberInRange(scores.feedbackNeed, 0, 10)
        && numberInRange(scores.cooperation, 0, 10);
    }

    function validFactorReliability(reliability) {
      return reliability is map
        && reliability.keys().hasOnly([
          'neuroticism',
          'extraversion',
          'dominance',
          'ruleAdaptation',
          'empathy',
          'stressResponse',
          'feedbackNeed',
          'cooperation',
        ])
        && numberInRange(reliability.neuroticism, 0, 10)
        && numberInRange(reliability.extraversion, 0, 10)
        && numberInRange(reliability.dominance, 0, 10)
        && numberInRange(reliability.ruleAdaptation, 0, 10)
        && numberInRange(reliability.empathy, 0, 10)
        && numberInRange(reliability.stressResponse, 0, 10)
        && numberInRange(reliability.feedbackNeed, 0, 10)
        && numberInRange(reliability.cooperation, 0, 10);
    }

    function validSystemIndices(indices) {
      return indices is map
        && indices.keys().hasOnly([
          'conflictLoad',
          'teamStabilityReserve',
          'communicationClarity',
          'autonomyBalance',
          'profileIntegrity',
        ])
        && numberInRange(indices.conflictLoad, 0, 10)
        && numberInRange(indices.teamStabilityReserve, 0, 10)
        && numberInRange(indices.communicationClarity, 0, 10)
        && numberInRange(indices.autonomyBalance, 0, 10)
        && numberInRange(indices.profileIntegrity, 0, 10);
    }

    function validDiscoverProfileWrite(userId) {
      return request.resource.data.keys().hasOnly([
          'userId',
          'name',
          'age',
          'gender',
          'avatarInitials',
          'avatarUrl',
          'factorScores',
          'factorReliability',
          'egoState',
          'systemIndices',
          'profileIntegrity',
          'questionnaireCompleted',
          'discoverVisible',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userId == userId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.age is int
        && request.resource.data.age >= 16
        && request.resource.data.age <= 90
        && request.resource.data.gender is string
        && request.resource.data.avatarInitials is string
        && request.resource.data.avatarUrl is string
        && validFactorScores(request.resource.data.factorScores)
        && validFactorReliability(request.resource.data.factorReliability)
        && request.resource.data.egoState is string
        && validSystemIndices(request.resource.data.systemIndices)
        && numberInRange(request.resource.data.profileIntegrity, 0, 10)
        && request.resource.data.questionnaireCompleted == true
        && request.resource.data.discoverVisible == true
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    function pendingInvite(teamId) {
      return get(
        /databases/$(database)/documents/teamInvites/$(teamId + "_" + request.auth.uid)
      );
    }

    function teamJoinCodeDoc(code) {
      return get(/databases/$(database)/documents/teamJoinCodes/$(code));
    }

    function hasInviteDraftKeys() {
      return request.resource.data.keys().hasOnly([
        'teamId',
        'teamName',
        'teamDescription',
        'teamGoal',
        'fromUid',
        'fromName',
        'fromAvatarInitials',
        'toUid',
        'toName',
        'toAvatarInitials',
        'status',
        'source',
        'joinCode',
        'createdAt',
        'updatedAt',
      ]);
    }

    function isDirectInviteDraft() {
      return hasInviteDraftKeys()
        && request.resource.data.status == 'pending'
        && request.resource.data.source == 'direct'
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.joinCode == null
        && getAfter(
          /databases/$(database)/documents/teams/$(request.resource.data.teamId)
        ).data.createdBy == request.auth.uid;
    }

    function isCodeInviteDraft() {
      return hasInviteDraftKeys()
        && request.resource.data.status == 'pending'
        && request.resource.data.source == 'code'
        && request.resource.data.toUid == request.auth.uid
        && request.resource.data.fromUid != request.auth.uid
        && request.resource.data.joinCode is string
        && teamJoinCodeDoc(request.resource.data.joinCode).data.active == true
        && teamJoinCodeDoc(request.resource.data.joinCode).data.teamId == request.resource.data.teamId
        && teamJoinCodeDoc(request.resource.data.joinCode).data.createdBy == request.resource.data.fromUid
        && teamJoinCodeDoc(request.resource.data.joinCode).data.teamName == request.resource.data.teamName
        && teamJoinCodeDoc(request.resource.data.joinCode).data.teamDescription == request.resource.data.teamDescription
        && teamJoinCodeDoc(request.resource.data.joinCode).data.teamGoal == request.resource.data.teamGoal
        && teamJoinCodeDoc(request.resource.data.joinCode).data.createdByName == request.resource.data.fromName
        && teamJoinCodeDoc(request.resource.data.joinCode).data.createdByAvatarInitials == request.resource.data.fromAvatarInitials;
    }

    function canReuseCodeInvite() {
      return resource.data.status == 'declined'
        && resource.data.toUid == request.auth.uid
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.toUid == resource.data.toUid
        && request.resource.data.createdAt == resource.data.createdAt
        && isCodeInviteDraft();
    }

    function canAcceptInvite(teamId) {
      let invite = pendingInvite(teamId);
      return invite.data != null
        && invite.data.status == 'pending'
        && invite.data.toUid == request.auth.uid
        && !(request.auth.uid in resource.data.memberIds)
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
        && request.resource.data.memberIds.hasAll(resource.data.memberIds)
        && request.resource.data.joinCode == resource.data.joinCode
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.name == resource.data.name
        && request.resource.data.description == resource.data.description
        && request.resource.data.goal == resource.data.goal
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.memberSnapshots is list
        && resource.data.memberSnapshots is list
        && request.resource.data.memberSnapshots.size() == resource.data.memberSnapshots.size() + 1
        && request.resource.data.updatedAt is string
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly(['memberIds', 'memberSnapshots', 'analysis', 'updatedAt']);
    }

    function canReadInvitedTeam(teamId) {
      let invite = pendingInvite(teamId);
      return invite.data != null
        && invite.data.status == 'pending'
        && invite.data.toUid == request.auth.uid;
    }

    function validMatchActionBase(actionId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'fromUid',
          'toUid',
          'decision',
          'compatibility',
          'conflictRisk',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.id == actionId
        && actionId == request.auth.uid + "_" + request.resource.data.toUid
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.decision in ['like', 'pass']
        && (
          request.resource.data.compatibility is int
          || request.resource.data.compatibility is float
        )
        && request.resource.data.compatibility >= 0
        && request.resource.data.compatibility <= 100
        && request.resource.data.conflictRisk is string
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    function validMatchActionCreate(actionId) {
      return validMatchActionBase(actionId);
    }

    function validMatchActionUpdate(actionId) {
      return validMatchActionBase(actionId)
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function validTeamCreate() {
      return request.resource.data.keys().hasOnly([
          'name',
          'description',
          'goal',
          'joinCode',
          'createdBy',
          'memberIds',
          'memberSnapshots',
          'analysis',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.description is string
        && request.resource.data.goal is string
        && request.resource.data.joinCode is string
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() == 1
        && request.resource.data.memberIds[0] == request.auth.uid
        && request.resource.data.memberSnapshots is list
        && request.resource.data.memberSnapshots.size() == 1
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    function validTeamCoreUpdate() {
      return request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.name == resource.data.name
        && request.resource.data.description == resource.data.description
        && request.resource.data.goal == resource.data.goal
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function canRefreshOwnTeamSnapshot() {
      return request.auth.uid in resource.data.memberIds
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds == resource.data.memberIds
        && request.resource.data.joinCode == resource.data.joinCode
        && request.resource.data.memberSnapshots is list
        && resource.data.memberSnapshots is list
        && request.resource.data.memberSnapshots.size() == resource.data.memberSnapshots.size()
        && request.resource.data.updatedAt is string
        && validTeamCoreUpdate()
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly(['memberSnapshots', 'analysis', 'updatedAt']);
    }

    function canManageTeamJoinCode() {
      return request.auth.uid == resource.data.createdBy
        && request.resource.data.memberIds == resource.data.memberIds
        && request.resource.data.memberSnapshots == resource.data.memberSnapshots
        && request.resource.data.analysis == resource.data.analysis
        && request.resource.data.joinCode is string
        && request.resource.data.updatedAt is string
        && validTeamCoreUpdate()
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly(['joinCode', 'updatedAt']);
    }

    function validTeamJoinCodeCreate(code) {
      return request.resource.data.keys().hasOnly([
          'code',
          'teamId',
          'teamName',
          'teamDescription',
          'teamGoal',
          'createdBy',
          'createdByName',
          'createdByAvatarInitials',
          'active',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.code == code
        && request.resource.data.teamId is string
        && request.resource.data.teamName is string
        && request.resource.data.teamDescription is string
        && request.resource.data.teamGoal is string
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdByName is string
        && request.resource.data.createdByAvatarInitials is string
        && request.resource.data.active == true
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string
        && getAfter(
          /databases/$(database)/documents/teams/$(request.resource.data.teamId)
        ).data.createdBy == request.auth.uid;
    }

    function canUpdateTeamJoinCode() {
      return resource.data.createdBy == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'code',
          'teamId',
          'teamName',
          'teamDescription',
          'teamGoal',
          'createdBy',
          'createdByName',
          'createdByAvatarInitials',
          'active',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.code == resource.data.code
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.teamName == resource.data.teamName
        && request.resource.data.teamDescription == resource.data.teamDescription
        && request.resource.data.teamGoal == resource.data.teamGoal
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdByName == resource.data.createdByName
        && request.resource.data.createdByAvatarInitials == resource.data.createdByAvatarInitials
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.active is bool
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly(['active', 'updatedAt']);
    }

    match /profiles/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /publicProfiles/{userId} {
      allow read, create, update: if false;
      allow delete: if isOwner(userId);
    }

    match /discoverProfiles/{userId} {
      allow read: if isOwner(userId) || canBrowseDiscover();
      allow create, update: if isOwner(userId)
        && validDiscoverProfileWrite(userId);
      allow delete: if isOwner(userId);
    }

    match /teams/{teamId} {
      allow read: if isSignedIn()
        && (
          request.auth.uid in resource.data.memberIds
          || canReadInvitedTeam(teamId)
        );
      allow create: if isSignedIn()
        && validTeamCreate();
      allow update: if isSignedIn()
        && (
          canRefreshOwnTeamSnapshot()
          || canManageTeamJoinCode()
          || canAcceptInvite(teamId)
        );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.createdBy;
    }

    match /teamInvites/{inviteId} {
      allow read: if isSignedIn()
        && (
          resource.data.fromUid == request.auth.uid
          || resource.data.toUid == request.auth.uid
        );
      allow create: if isSignedIn()
        && (
          isDirectInviteDraft()
          || isCodeInviteDraft()
        );
      allow update: if isSignedIn()
        && (
          (
            resource.data.toUid == request.auth.uid
            && resource.data.status == 'pending'
            && request.resource.data.fromUid == resource.data.fromUid
            && request.resource.data.toUid == resource.data.toUid
            && request.resource.data.teamId == resource.data.teamId
            && request.resource.data.teamName == resource.data.teamName
            && request.resource.data.teamDescription == resource.data.teamDescription
            && request.resource.data.teamGoal == resource.data.teamGoal
            && request.resource.data.fromName == resource.data.fromName
            && request.resource.data.fromAvatarInitials == resource.data.fromAvatarInitials
            && request.resource.data.toName == resource.data.toName
            && request.resource.data.toAvatarInitials == resource.data.toAvatarInitials
            && request.resource.data.source == resource.data.source
            && request.resource.data.joinCode == resource.data.joinCode
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.status in ['accepted', 'declined']
            && request.resource.data
              .diff(resource.data)
              .affectedKeys()
              .hasOnly(['status', 'respondedAt', 'updatedAt'])
          )
          || canReuseCodeInvite()
        );
      allow delete: if false;
    }

    match /teamJoinCodes/{code} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn()
        && validTeamJoinCodeCreate(code);
      allow update: if isSignedIn()
        && canUpdateTeamJoinCode();
      allow delete: if false;
    }

    match /matchActions/{actionId} {
      allow read: if isSignedIn()
        && (resource == null
          || resource.data.fromUid == request.auth.uid
          || resource.data.toUid == request.auth.uid);
      allow create: if isSignedIn()
        && validMatchActionCreate(actionId);
      allow update: if isSignedIn()
        && validMatchActionUpdate(actionId);
      allow delete: if isSignedIn() && resource.data.fromUid == request.auth.uid;
    }
  }
}
